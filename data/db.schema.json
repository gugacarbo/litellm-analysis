{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "./db.schema.json",
  "title": "LiteLLM Analytics Database Configuration",
  "description": "Configuration schema for LiteLLM analytics dashboard including models, agents, and categories",
  "type": "object",
  "required": [
    "$schema",
    "version",
    "litellm",
    "models",
    "agents",
    "categories",
    "globalFallbackModel"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "URI reference to this JSON schema"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Configuration version number"
    },
    "litellm": {
      "type": "object",
      "required": ["baseUrl", "apiKey"],
      "properties": {
        "baseUrl": {
          "type": "string",
          "format": "uri",
          "description": "LiteLLM API base URL"
        },
        "apiKey": {
          "type": "string",
          "description": "LiteLLM API key"
        }
      },
      "additionalProperties": false
    },
    "models": {
      "type": "object",
      "description": "Map of model configurations keyed by model identifier",
      "additionalProperties": {
        "type": "object",
        "required": ["displayName", "ownedBy", "contextLength", "maxOutput"],
        "properties": {
          "displayName": {
            "type": "string",
            "description": "Human-readable model name"
          },
          "ownedBy": {
            "type": "string",
            "description": "Organization or entity that owns the model"
          },
          "family": {
            "type": "string",
            "description": "Model family or series"
          },
          "contextLength": {
            "type": "integer",
            "minimum": 1,
            "description": "Maximum context length in tokens"
          },
          "maxOutput": {
            "type": "integer",
            "minimum": 1,
            "description": "Maximum output length in tokens"
          },
          "cost": {
            "type": "object",
            "required": ["input", "output"],
            "properties": {
              "input": {
                "type": "number",
                "minimum": 0,
                "description": "Input cost per million tokens"
              },
              "output": {
                "type": "number",
                "minimum": 0,
                "description": "Output cost per million tokens"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "agents": {
      "type": "object",
      "description": "Map of agent configurations keyed by agent identifier",
      "additionalProperties": {
        "type": "object",
        "required": ["fallbackModels", "description"],
        "properties": {
          "model": {
            "type": "string",
            "description": "Primary model identifier for this agent (can be empty)"
          },
          "fallbackModels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Ordered list of fallback model identifiers"
          },
          "description": {
            "type": "string",
            "description": "Agent role and responsibility description"
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$",
            "description": "Hex color code for agent identification"
          },
          "disable": {
            "type": "boolean",
            "default": false,
            "description": "Whether the agent is disabled"
          },
          "tools": {
            "type": "object",
            "description": "Agent tool configurations"
          },
          "mode": {
            "type": "string",
            "enum": ["subagent", "standalone", "orchestrator"],
            "description": "Agent execution mode"
          },
          "permission": {
            "type": "object",
            "description": "Agent permission settings"
          }
        },
        "additionalProperties": false
      }
    },
    "categories": {
      "type": "object",
      "description": "Map of task category configurations keyed by category identifier",
      "additionalProperties": {
        "type": "object",
        "required": ["fallbackModels", "description"],
        "properties": {
          "model": {
            "type": "string",
            "description": "Default model identifier for this category (can be empty)"
          },
          "fallbackModels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Ordered list of fallback model identifiers"
          },
          "description": {
            "type": "string",
            "description": "Category description and usage guidance"
          }
        },
        "additionalProperties": false
      }
    },
    "globalFallbackModel": {
      "type": "string",
      "description": "Default fallback model identifier used when no specific fallback is available"
    }
  },
  "additionalProperties": false
}
